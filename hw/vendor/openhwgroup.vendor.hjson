      url: "https://github.com/openhwgroup/cv32e40p.git",
      rev: "a43277c0dc64c02be3f5d713438f315ecffde2b9",
    },

    patch_dir: "patches/openhwgroup_cv32e40p",

    exclude_from_upstream: [
